<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.jdbc.Controller">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Form fields -->
    <GridPane hgap="10" vgap="10">
        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

        <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtCourse" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Year Level:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ChoiceBox fx:id="cbYear" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="150"/>
    </GridPane>

    <!-- Buttons -->
    <HBox spacing="10">
        <Button text="Add" onAction="#addStudent"/>
        <Button text="Update" onAction="#updateStudent"/>
        <Button text="Delete" onAction="#deleteStudent"/>
        <Button text="Clear" onAction="#clearFields"/>
    </HBox>

    <!-- TableView -->
    <TableView fx:id="table" prefHeight="300">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
            <TableColumn fx:id="colCourse" text="Course" prefWidth="150"/>
            <TableColumn fx:id="colYear" text="Year Level" prefWidth="100"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>